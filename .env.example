# RM117 BMS — environment variables (Phase 0)
# Copy to .env and fill in as accounts are created. The app boots with mock data
# until SUPABASE_URL + SUPABASE_SERVICE_KEY are set.

# --- Supabase (source of truth — Phase 1) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Google Sheet (migration seed, Viewer-only — Phase 2 import + fallback through Phase 3) ---
SHEET_ID=
# Service account: either a path to the downloaded key JSON...
GOOGLE_APPLICATION_CREDENTIALS=
# ...or the email + private key inline (use \n for newlines in the key)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# --- Email bridge (Resend; Postmark fallback) ---
RESEND_API_KEY=
# POSTMARK_SERVER_TOKEN=

# --- DocuSign (proposals — Phase 5) ---
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY=

# --- QuickBooks Online API (outbound invoicing — Phase 5) ---
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REFRESH_TOKEN=
QBO_REALM_ID=

# --- Calendar (dashboard widget) ---
COMPANY_CALENDAR_ID=

# --- Clerk (staff auth; client role in Phase 7) ---
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
